{
  "manifest_version": 3,
  "name": "Gemini Chat Backup",
  "version": "1.0.0",
  "description": "自動將 Google Gemini 對話備份為 Markdown 格式到本地資料夾",
  "permissions": ["storage", "alarms", "scripting", "tabs"],
  "host_permissions": ["https://gemini.google.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Gemini Chat Backup"
  }
}
